              "getting-started/installation",
              "getting-started/claude-code",
              "getting-started/other-clients",
              "getting-started/plans"
            ]
          },
          {
            "group": "MCP reference",
            "pages": [
              "mcp/index",
              "mcp/tools",
              "mcp/file-watching",
              "mcp/configuration"
            ]
          },
          {
            "group": "Packages",
            "pages": [
              "packages/index"
            ]
          },
          {
            "group": "Architecture",
            "pages": [
              "architecture/index",
              "architecture/embeddings",
              "architecture/code-chunking"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "MCP backend endpoints",
            "pages": [
              "api-reference/endpoint/embeddings",
              "api-reference/endpoint/rerank",
              "api-reference/endpoint/index-chunks",
              "api-reference/endpoint/search",
              "api-reference/endpoint/repos",
              "api-reference/endpoint/files",
              "api-reference/endpoint/sync-save",
              "api-reference/endpoint/sync-load"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/yxanul/sharc-docs",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:contact@sharc.sh"
      }
    ],
    "primary": {
      "type": "button",
